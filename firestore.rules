rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /quizzes/{quizId} {
      allow read: if true;

      // Admin panel can create/edit/delete quizzes after Firebase auth
      allow create, update, delete: if request.auth != null;
    }

    match /quizResults/{resultId} {
      allow read: if true;

      // Students can submit only valid result format
      allow create: if
        request.resource.data.userName is string &&
        request.resource.data.schoolName is string &&
        request.resource.data.standard is string &&
        request.resource.data.quizId is string &&
        request.resource.data.quizTitle is string &&
        request.resource.data.score is number &&
        request.resource.data.totalQuestions is number &&
        request.resource.data.percentage is number &&
        request.resource.data.percentage >= 0 &&
        request.resource.data.percentage <= 100 &&
        request.resource.data.score >= 0 &&
        request.resource.data.totalQuestions == 15 &&
        request.resource.data.standard in ["5", "6", "7", "8", "9"];

      // Admin can reset/delete results
      allow update, delete: if request.auth != null;
    }
  }
}